PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/password_manager_pro
JWT_SECRET=change_me_to_a_long_random_secret
# 32 bytes base64 (AES-256). Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=base64_32_byte_key_here
CLIENT_ORIGIN=http://localhost:3000
# Optional: promote roles on login (exact email match, lowercase)
# ADMIN_EMAIL=admin@example.com
# ORG_EMAIL=org@example.com

